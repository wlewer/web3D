# 腾讯混元3D API配置
# 获取地址：https://console.cloud.tencent.com/cam/capi
HUNYUAN3D_SECRET_ID=your_secret_id_here
HUNYUAN3D_SECRET_KEY=your_secret_key_here

# API版本配置
# rapid=标准版（30-60秒，10积分）
# pro=专业版（60-120秒，20积分）
# express=极速版（10-20秒，5积分）- 注意：当前SDK不支持，会降级为rapid
HUNYUAN3D_API_VERSION=rapid

# 生成模式配置
# mock=演示模式（返回示例模型）
# cloud=云端API模式（调用腾讯混元3D）
HUNYUAN3D_MODE=cloud

# 其他配置
DEBUG=true
APP_NAME=Web3D Platform
APP_VERSION=1.0.0
