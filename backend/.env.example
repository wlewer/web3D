# AI 3D生成 - 环境配置

# ==================== 当前模式 ====================
# mock = 模拟模式（用于UI测试，无需GPU）
# cpu = CPU模式（本地运行，速度较慢）
# gpu = GPU模式（需要NVIDIA显卡）
GENERATION_MODE=mock

# ==================== 本地CPU配置 ====================
# 适用于无GPU电脑
CPU_MODE=true
CPU_NUM_THREADS=4  # 并行线程数
CPU_BATCH_SIZE=1   # 批处理大小

# ==================== GPU配置 ====================
# 适用于服务器环境
CUDA_DEVICE=0
GPU_MEMORY_FRACTION=0.9

# ==================== TripoSR CPU配置 ====================
TRIPROSR_MODEL=VAST-AI/TripoSR
TRIPROSR_DEVICE=cpu
TRIPROSR_TARGET_FACES=5000

# ==================== 文件存储 ====================
UPLOAD_DIR=./uploads
GENERATION_OUTPUT_DIR=./uploads/generation
MODEL_CACHE_DIR=./cache/models

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=true
