## 七、避免连锁反应的规范

### 7.1 导出管理

```typescript
// ✅ 推荐：显式导出，使用index.ts统一管理
// components/common/Button/index.ts
export { Button } from './Button';
export type { ButtonProps } from './Button';
export { ButtonSkeleton } from './ButtonSkeleton';

// ❌ 避免：直接导出，导致追踪困难
// components/common/Button.tsx
export { Button, ButtonSkeleton, ButtonGroup } from './Button';
```

### 7.2 接口稳定性

```typescript
// ✅ 推荐：显式声明接口
export interface ModelViewerProps {
  modelUrl: string;
  onLoad?: () => void;
  onError?: (error: Error) => void;
}

// ❌ 避免：内部属性泄漏
export interface ModelViewerProps {
  // 内部属性不应暴露
  _internalRef?: React.RefObject<any>;
}
```

### 7.3 版本兼容

```typescript
// ✅ 推荐：添加废弃标记
/**
 * @deprecated Use `useNewAuth` instead
 */
export function useAuth(): AuthContext {
  // ...
}

// ✅ 推荐：类型兼容
type LegacyProps = NewProps & {
  legacyField?: string;
};
```

